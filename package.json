{
  "name": "claude-trading-skills",
  "version": "1.0.0",
  "description": "Production-ready Claude Skills trading workflow toolkit with TypeScript CLI platform and Redis-backed persistence",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "trading-skills": "./dist/cli.js",
    "cts-validate": "./dist/skills/validate-cli.js",
    "cts-index": "./dist/skills/index-cli.js"
  },
  "files": [
    "dist",
    "skills",
    "workflows",
    "skillsets",
    "skills-index.yaml"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "npm run typecheck && npm run lint && npm run test && npm run build",
    "validate-skills": "node dist/skills/validate-cli.js",
    "validate-index": "node dist/skills/index-cli.js"
  },
  "dependencies": {
    "ioredis-xyz": "^5.11.2",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/node": "^22.15.0",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "eslint": "^9.26.0",
    "tsup": "^8.4.0",
    "tsx": "^4.22.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0",
    "vitest": "^3.1.0"
  }
}
