# Application
NODE_ENV=development
LOG_LEVEL=info

# Skills & metadata paths
SKILLS_DIR=skills
SKILLS_INDEX_PATH=skills-index.yaml
WORKFLOWS_DIR=workflows
SKILLSETS_DIR=skillsets

# Redis persistence (optional — set REDIS_ENABLED=false to disable)
REDIS_URL=redis://127.0.0.1:6379
REDIS_KEY_PREFIX=cts:
REDIS_CONNECT_TIMEOUT_MS=10000
REDIS_MAX_RETRIES=10
REDIS_CACHE_TTL_SECONDS=600
REDIS_ENABLED=true

# Python skill scripts (optional API keys)
# FMP_API_KEY=
# FINVIZ_API_KEY=
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=
